# Application
DEBUG=false
LOG_LEVEL=INFO

# API
API_PREFIX=/api

# LLM Configuration
# Default: mock (no API key needed, for development/testing)
# For real AI: set LLM_PROVIDER=gemini and provide GEMINI_API_KEY
LLM_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Supabase Configuration
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
MEMORY_ENABLED=false

# Future configurations
# DATABASE_URL=