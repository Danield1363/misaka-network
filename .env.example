# Application
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=development

# API
API_PREFIX=/api

# LLM Configuration
# Default: mock (no API key needed, for development/testing)
# For real AI: set LLM_PROVIDER=gemini and provide GEMINI_API_KEY
LLM_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_SECONDARY_FALLBACK_MODEL=gemini-2.5-flash-lite
GEMINI_MAX_CONTEXT_CHARS=12000
GEMINI_MAX_OUTPUT_TOKENS=1024
GEMINI_RATE_LIMIT_COOLDOWN_SECONDS=60

# Supabase Configuration
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
MEMORY_ENABLED=false
NOTIFICATIONS_ENABLED=false
NOTIFICATION_INGEST_TOKEN=your-secret-token-here

# Feature Flags
DESKTOP_CONTROL_ENABLED=true
ANDROID_BRIDGE_ENABLED=false
WAKE_WORD_ENABLED=false
