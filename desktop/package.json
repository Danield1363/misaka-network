{
  "name": "misaka-desktop",
  "version": "0.3.7",
  "description": "Misaka Network Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "debug": "electron . --enable-logging",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis portable"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.daniel.misaka",
    "productName": "Misaka Network",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "assets/**/*",
      "control/**/*",
      "voice/nativeVoiceBridge.js",
      "voice/python/**/*"
    ],
    "extraResources": [
      {
        "from": "../dashboard",
        "to": "dashboard",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "author": "Daniel",
  "license": "MIT"
}
